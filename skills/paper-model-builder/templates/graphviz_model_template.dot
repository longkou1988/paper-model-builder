digraph ResearchModel {
  rankdir=LR;
  node [shape=box, style=rounded];

  "Independent Variable" -> "Dependent Variable" [label="H1"];
  "Independent Variable" -> "Mediator" [label="H2a"];
  "Mediator" -> "Dependent Variable" [label="H2b"];
  "Moderator" -> "Independent Variable" [label="H3", style=dashed];
  "Control Variables" -> "Dependent Variable" [style=dashed];
}
